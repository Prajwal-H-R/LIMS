+
+    if normalized == "csv":
+        output = StringIO()
+        writer = csv.writer(output)
+        writer.writerow(TEMPLATE_COLUMNS)
+
+        content = output.getvalue().encode("utf-8-sig")
+        return (
+            content,
+            "text/csv",
+            "htw_pressure_gauge_resolution_template.csv",
+        )
+
+    wb = Workbook()
