+    info["A2"] = "All fields in the main sheet are mandatory."
+    info["A3"] = "Use numeric values for all columns."
+    info["A4"] = "Example lower_measure_range"
+    info["B4"] = "200"
+    info["A5"] = "Example higher_measure_range"
+    info["B5"] = "1500"
